// Limity baterii Li-Ion 2s (Nominal 7.4V)
#define MAX_V_IN		30.0f	// [V] Max napięcie wejściowe
#define MAX_V_OUT       8.40f   // [V] Max napięcie (CV cut-off)
#define MAX_I_OUT       1.80f   // [A] Max prąd ładowania (CC limit)
#define MIN_V_IN_OFFSET 1.50f   // [V] O ile Vin musi być wyższe od Vout, aby startować
#define MIN_V_BAT_SAFE  5.50f   // [V] Poniżej tego napięcia bateria może być uszkodzona

// Kalibracja ADC
#define ADC_SCALE_VIN   0.008f  // Przelicznik RAW ADC -> Volty dla wejścia
#define ADC_SCALE_VOUT  0.003f  // Przelicznik RAW ADC -> Volty dla wyjścia
#define ADC_SCALE_IOUT  0.0008f  // Przelicznik RAW ADC -> Ampery

// Ustawienia PWM
#define PWM_PERIOD      639    // ARR timera
#define MAX_DUTY        607     // 95% max wypełnienie (dla bootstrapu drivera)
#define MIN_DUTY        0       // 0%

// Ustawienia bufora DMA
#define ADC_CHANNELS    3   // Vin, Vout, Iout
#define DMA_SAMPLES     10  // Ilość próbek na kanał

// Współczynnik filtra dolnoprzepustowego (0.0 do 1.0).
#define FILTER_ALPHA_V  0.2f  // Dla napięć (zazwyczaj stabilniejsze)
#define FILTER_ALPHA_I  0.2f  // Dla prądu (wymaga mocniejszego tłumienia)
