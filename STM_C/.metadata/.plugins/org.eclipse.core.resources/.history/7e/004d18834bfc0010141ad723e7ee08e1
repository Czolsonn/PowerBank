// Logika kontroli ładowania Li-ion w układzie synchornicznego buck-convertera //
void Calc_ADC(void){
	//Przeliczanie jednostek na wartości mierzone
	uint32_t sum_vin = 0;
	uint32_t sum_vout = 0;
	uint32_t sum_iout = 0;

	// KROK 1: Sumowanie danych z bufora DMA
	// Bufor jest przeplatany: [CH0, CH1, CH2, CH0, CH1, CH2...]
	for (int i = 0; i < DMA_SAMPLES; i++) {
		sum_vin  += adc_dma_buffer[(i * ADC_CHANNELS) + 0]; // Rank 1: Vin
		sum_vout += adc_dma_buffer[(i * ADC_CHANNELS) + 1]; // Rank 2: Vout
		sum_iout += adc_dma_buffer[(i * ADC_CHANNELS) + 2]; // Rank 3: Iout
	}

	// Oblicz średnią surową (Raw)
	float raw_vin_avg  = (float)sum_vin / DMA_SAMPLES;
	float raw_vout_avg = (float)sum_vout / DMA_SAMPLES;
	float raw_iout_avg = (float)sum_iout / DMA_SAMPLES;

	// Konwersja na jednostki fizyczne
	float inst_vin  = raw_vin_avg * ADC_SCALE_VIN;
	float inst_vout = raw_vout_avg * ADC_SCALE_VOUT;
	float inst_iout = raw_iout_avg * ADC_SCALE_IOUT;

	sys.v_in_inst  = inst_vin;
	sys.v_out_inst = inst_vout;
	sys.i_out_inst = inst_iout;

	// KROK 2: Filtracja EMA (To nadal warto zostawić!)
	// DMA wygładza szum "szybki" (wysokoczęstotliwościowy),
	// EMA wygładza "pływanie" (niskoczęstotliwościowe).

	static uint8_t first_run = 1;
	if (first_run) {
		sys.v_in = inst_vin;
		sys.v_out = inst_vout;
		sys.i_out = inst_iout;
		first_run = 0;
	} else {
		sys.v_in  = Filter_EMA(inst_vin, sys.v_in, FILTER_ALPHA_V);
		sys.v_out = Filter_EMA(inst_vout, sys.v_out, FILTER_ALPHA_V);
		sys.i_out = Filter_EMA(inst_iout, sys.i_out, FILTER_ALPHA_I);
	}

	// Obliczenie mocy
	sys.power_out = sys.v_in * sys.i_out;
}

void Control_Loop(void) {
    // Zabezpieczenia nadrzędne (HARD LIMITS)
	// Over-Voltage Protection (OVP) - margines bezpieczeństwa np. +0.3V
    if (sys.v_out_inst > (MAX_V_OUT + 0.2f)) {
        // Krytyczne przeładowanie - natychmiast STOP
        Buck_Enable(0);
        duty_cycle = 0;
        Set_PWM_Duty(0);
        current_state = STATE_ERROR;
        return;
    }

    // Over-Voltage Protection (OVP) - wejścia > MAX_V_IN
    if (sys.v_in_inst > MAX_V_IN) {
            // Krytyczna wartość napięcia wejściowego - natychmiast STOP
            Buck_Enable(0);
            duty_cycle = 0;
            Set_PWM_Duty(0);
            current_state = STATE_ERROR;
            return;
        }

    // Over-Current Protection (OCP) - margines np. +0.5A ponad limit
        if (sys.i_out_inst > (MAX_I_OUT + 0.3f)) {
            Buck_Enable(0);
            duty_cycle = 0;
            Set_PWM_Duty(0);
            current_state = STATE_ERROR;
            return;
        }

    // Maszyna stanów
    switch (current_state) {
        case STATE_IDLE:
            duty_cycle = 0;
            Buck_Enable(0);

            // Warunek startu: Słońce świeci (Vin > Vbat + margines)
            if (sys.v_in > (sys.v_out + MIN_V_IN_OFFSET) && sys.v_out > MIN_V_BAT_SAFE) {
                current_state = STATE_SOFT_START;
                Buck_Enable(1);
            }
            break;

        case STATE_SOFT_START:
            // Powolne narastanie prądu, aby nie uszkodzić wejścia/wyjścia
            duty_cycle += 2; // Powoli zwiększaj
            uint16_t cycle_min = (sys.v_out/sys.v_in)*PWM_PERIOD; // Wartość progowa dla, której V_buck = V_bat
            if (duty_cycle >= cycle_min || sys.i_out > 0.1f) { // Jeśli prąd popłynął
                current_state = STATE_CHARGING;
            }
            // Zabezpieczenie powrotu
            if (sys.v_in <= sys.v_out) current_state = STATE_IDLE;
            break;

        case STATE_CHARGING:
            /*
             * ALGORYTM HYBRYDOWY MPPT + CC/CV
             * Priorytety:
             * 1. Nie przekraczaj napięcia MAX (CV)
             * 2. Nie przekraczaj prądu MAX (CC)
             * 3. Jeśli powyższe OK -> Szukaj punktu mocy (MPPT P&O)
             */

            // --- REGULATOR OGRANICZEŃ (LIMITER) ---
            int limit_active = 0;

            // Ograniczenie napięciowe (CV - Constant Voltage)
            if (sys.v_out >= MAX_V_OUT) {
                if (duty_cycle > 0) duty_cycle--; // Zmniejsz duty
                limit_active = 1;
            }
            // Histereza CV (delikatne podejście)
            else if (sys.v_out > (MAX_V_OUT - 0.05f)) {
                 // Nie zwiększaj duty w strefie bliskiej max
                 limit_active = 1;
            }

            // Ograniczenie prądowe (CC - Constant Current)
            if (sys.i_out >= MAX_I_OUT) {
                if (duty_cycle > 0) duty_cycle--; // Zmniejsz duty
                limit_active = 1;
            }

            // --- ALGORYTM MPPT (Perturb & Observe) ---
            // Działa tylko wtedy, gdy nie uderzamy w limity baterii
            if (!limit_active) {
                // Czy moc wzrosła?
                if (sys.power_out > sys.power_prev) {
                    // Tak: idziemy dalej w tym samym kierunku
                    duty_cycle += mppt_direction;
                } else {
                    // Nie: moc spadła, zmieniamy kierunek
                    mppt_direction = -mppt_direction;
                    duty_cycle += mppt_direction;
                }

                sys.power_prev = sys.power_out;
            }

            // Sprawdzenie "Under Voltage Lockout" dla panelu
            if (sys.v_in < sys.v_out + 0.5f) {
                current_state = STATE_IDLE;
            }
            break;


        case STATE_ERROR:
            // Wymaga resetu lub histerezy powrotu
            if (sys.v_out_inst < MAX_V_OUT - 0.5f && sys.v_in_inst < MAX_V_IN - 1.0f){
                current_state = STATE_IDLE;
            }
            break;
    }

    // Zastosuj Duty Cycle z limitem Hard-Hardware
    if (duty_cycle > MAX_DUTY) duty_cycle = MAX_DUTY;
    if (duty_cycle < MIN_DUTY) duty_cycle = MIN_DUTY;

    Set_PWM_Duty(duty_cycle);
}

// Najważniejsze dane - logs
void Log_Status(void) {
    // Konwersja stanu na napis
    char state_str[10];
    switch (current_state) {
        case STATE_IDLE:       sprintf(state_str, "IDLE"); break;
        case STATE_SOFT_START: sprintf(state_str, "SOFT"); break;
        case STATE_CHARGING:   sprintf(state_str, "CHRG"); break;
        case STATE_ERROR:      sprintf(state_str, "ERR!"); break;
        default:               sprintf(state_str, "????"); break;
    }

    printf("[State: %s] Vin: %5.2fV | Vout: %5.2fV | Iout: %5.2fA | Pwr: %5.2fW | PWM: %3d | I_out_inst: %5.3fA \n",
           state_str,
           sys.v_in,
           sys.v_out,
           sys.i_out,
           sys.power_out,
           duty_cycle, sys.i_out_inst);
}

/**
 * @brief  Cyfrowy filtr dolnoprzepustowy (EMA)
 * @param  current_val: nowa zmierzona wartość
 * @param  prev_val: poprzednia przefiltrowana wartość (historia)
 * @param  alpha: współczynnik wygładzania (0.0 - 1.0)
 * @return Nowa przefiltrowana wartość
 */
float Filter_EMA(float current_val, float prev_val, float alpha) {
    return (alpha * current_val) + ((1.0f - alpha) * prev_val);
}

