/* USER CODE BEGIN 4 */
int __io_putchar(int ch) // print -> UART
{
    if (ch == '\n') {
        uint8_t ch2 = '\r';
        HAL_UART_Transmit(&huart1, &ch2, 1, HAL_MAX_DELAY);
    }
    HAL_UART_Transmit(&huart1, (uint8_t*)&ch, 1, HAL_MAX_DELAY);
    return 1;
}

void HAL_GPIO_EXTI_CALLBACK(uint16_t GPIO_Pin){ // obsługa przerwań (USB - FAULT)
	if (GPIO_Pin == FAULT_Pin){
		HAL_GPIO_WritePin(FAULT_GPIO_Port, FAULT_Pin, GPIO_PIN_RESET);
		printf("FAULT!!!\n");
	}
}
