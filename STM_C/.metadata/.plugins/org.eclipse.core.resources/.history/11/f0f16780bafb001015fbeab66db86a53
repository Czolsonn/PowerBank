  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART1_UART_Init();
  MX_ADC1_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  HAL_TIM_PWM_Start(&htim2,TIM_CHANNEL_2);
  volatile static uint16_t value[3]; // tablica uint16_t przechowująca pomiary adc (continuous)
  HAL_ADCEx_Calibration_Start(&hadc1);
  HAL_ADC_Start_DMA(&hadc1, (uint32_t*)value, 3); //Inicjalizacja DMA do pomiarów ADC na V_BB, V_BAT, I_OUT
  HAL_GPIO_WritePin(ENABLE_GPIO_Port, ENABLE_Pin, GPIO_PIN_RESET); //Domyślnie ENABLE dla BUCK na 0
  HAL_GPIO_WritePin(ENABLE_TPS_GPIO_Port,ENABLE_TPS_Pin, GPIO_PIN_RESET); //Domyślnie ENABLE_TPS dla USB na 0
  while (1)
  {
	  main_cycle();
	  printf("V_BB = %.3f [V], V_BAT = %.3f [V], I_OUT = %.3f [A]\n", (value[0]*3.3/4095)*10, (value[1]*3.3/4095)*3.7,(value[2]*3.3/4095));
	  printf("CHG = %d , CHG_HI = %d, FAULT = %d, LD_DET = %d, UFP = %d, EN = %d\n",read_pin(CHG_GPIO_Port,CHG_Pin),read_pin(CHG_HI_GPIO_Port,CHG_HI_Pin),read_pin(FAULT_GPIO_Port,FAULT_Pin),read_pin(LD_DET_GPIO_Port,LD_DET_Pin),read_pin(UFP_GPIO_Port,UFP_Pin),read_pin(ENABLE_TPS_GPIO_Port, ENABLE_TPS_Pin));
	  HAL_Delay(1000);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

